        "S31"
      ],
      "level": 4
    },
    {
      "main_responsibility": "T3雕刻",
      "task_id": "T3.1",
      "task_name": "雕刻創作之發想與構思",
      "output": null,
      "behaviors": [
        "依據前一階段原石的提供，構思雕刻的風格展現。",
        "融合原石特性與設計主題風格，進行雕刻形體的規劃。"
      ],
      "knowledge": [
        "K17",
        "K28"
      ],
      "skills": [
        "S07",
        "S35"
      ],
      "level": 4
    },
    {
      "main_responsibility": "T3雕刻",
      "task_id": "T3.2",
      "task_name": "打版、篩選雕刻方法或創作材料",
      "output": null,
      "behaviors": [
        "在寶玉石製品上進行雕刻成品之圖形設計，包含文字、圖案或裝飾線條等展現。",
        "選擇合適電動手工具及鑽頭，以達成所欲展現之美感效果。"
      ],
      "knowledge": [
        "K14",
        "K26",
