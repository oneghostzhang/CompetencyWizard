  "basic_info": {
    "category": "藝文與影音傳播／視覺藝術",
    "category_code": "AVA",
    "occupation": "珠寶及貴金屬製作人員（研磨）、視覺及藝術創作人才（雕刻）",
    "occupation_code": "7313、2651",
    "industry": [
      "藝術、娛樂及休閒服務業／創作及藝術表演業（俗稱「寶玉石工藝",
      "產業」）"
    ],
    "industry_code": [
      "R9010"
    ],
    "job_description": "選擇及辨識寶玉原石之形體、色彩、材質與價值，設計結合文化、藝術、生活等美感與功能特性，發揮研磨、雕刻及拋光等精細加工程序，發展成為具有裝飾、擺設等用途之寶玉石成品，並能夠營運寶玉石工藝工坊。",
    "level": 4,
    "requirements": ""
  },
  "competency_tasks": [
    {
      "main_responsibility": "T1選擇原石設計樣",
      "task_id": "T1.1",
      "task_name": "挑選寶玉原石",
      "output": "原石、原石採購合約",
      "behaviors": [
        "至礦產地、集散地挑選辨識合適寶玉石原石。",
        "運用寶玉石鑑定儀器確認原石。",
        "與賣方確認原石價格。",
        "完成交易，必要時簽訂合約，保障權益。",
        "確認原礦運輸方式，以及交貨期間之正確性與安全性。",
        "保存採購之原礦，包含存放地點與條件控制。"
      ],
      "knowledge": [
        "K02",
        "K03",
        "K10",
        "K11",
        "K01",
        "K04",
        "K05",
        "K06",
        "K07",
