        "K09",
        "K12",
        "K13"
      ],
      "skills": [
        "S01",
        "S02",
        "S05",
        "S03",
        "S04",
        "S06"
      ],
      "level": 4
    },
    {
      "main_responsibility": "T1選擇原石設計樣",
      "task_id": "T1.2",
      "task_name": "確定寶玉石設計形式",
      "output": "設計圖、樣品或模型",
      "behaviors": [
        "依據原石風貌進行初步設計，賦予設計意義。",
        "可進行徒手畫線或依模型版於原石作圖。",
        "瞭解顧客需求，辨別本地與國際市場趨勢。",
        "自行或與客戶討論，決定設計概念，並初步估計成本。",
        "必要時準備素描、圖片、說明文件、樣品或模型，以溝通設計理念。",
        "接受客戶委託設計與製作，提供原型及樣品，監督樣式、計畫、工具使用及製造過程。"
      ],
      "knowledge": [
        "K14",
        "K15",
        "K16",
        "K17",
        "K18",
        "K20",
        "K19"
      ],
      "skills": [
