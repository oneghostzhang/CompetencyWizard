        "S17"
      ],
      "level": 4
    },
    {
      "main_responsibility": "T2研磨",
      "task_id": "T2.1",
      "task_name": "輪磨成形",
      "output": "粗磨半成品",
      "behaviors": [
        "熟悉砂輪機的操作，可熟練更換砂輪與砂紙。",
        "依圖案或指示，運用砂輪機進行寶玉石之塑型、修整、重塑及改型，磨出寶玉石之形體輪廓。",
        "依據形體（刻面、弧面或其他），手工操作砂輪機，選擇合適轉速，進行粗磨修飾程序。",
        "維持手部的穩定性，同時運用眼力與聽力進行研磨工序。"
      ],
      "knowledge": [
        "K14",
        "K25",
        "K26"
      ],
      "skills": [
        "S27",
        "S28",
        "S25",
        "S26",
