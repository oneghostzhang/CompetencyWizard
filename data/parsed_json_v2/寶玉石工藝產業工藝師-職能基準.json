        "S53"
      ],
      "level": 3
    },
    {
      "main_responsibility": "T6工坊經營",
      "task_id": "T6.1",
      "task_name": "寶玉石之研究發展─技術精進與定價策略",
      "output": "寶玉石研發技術手冊",
      "behaviors": [
        "持續精進寶玉石加工技術。",
        "評估寶玉石成本，含原石、加工程序及完成狀態，訂定銷售價格。",
        "提升工藝能力，建立外部關係。"
      ],
      "knowledge": [
        "K48",
        "K17"
      ],
      "skills": [
        "S59",
