    },
    {
      "main_responsibility": "T6工坊經營",
      "task_id": "T6.2",
      "task_name": "寶玉石之價值行銷",
      "output": "工坊空間規劃圖",
      "behaviors": [
        "講述寶玉石價值與設計理念。",
        "講述寶玉石技術與心法，使客戶等關係人體會寶玉石工藝精神。",
        "於工坊內部規劃及營造藝術空間，展示個人或集體創作品。",
        "建立寶玉石工藝價值，參與外部活動或自行辦理活動，提高能見度。"
      ],
